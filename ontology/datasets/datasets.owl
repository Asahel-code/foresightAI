<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.foresightai.org/ontology/datasets#"
     xml:base="http://www.foresightai.org/ontology/datasets"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.foresightai.org/ontology/datasets"/>

    <!-- Classes -->

    <owl:Class rdf:about="http://www.foresightai.org/ontology/datasets#Dataset">
        <rdfs:comment xml:lang="en">Represents a collection of data, published or curated by a single source.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.foresightai.org/ontology/datasets#DataSource">
        <rdfs:comment xml:lang="en">Represents an external system or provider from which data is retrieved (e.g. Copnernicus, CHIRPS, OpenStreetMap).</rdfs:comment>
    </owl:Class>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/datasets#hasSource">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/datasets#Dataset"/>
        <rdfs:range rdf:resource="http://www.foresightai.org/ontology/datasets#DataSource"/>
        <rdfs:comment xml:lang="en">Links a dataset to its originating datasource.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Datatype Properties -->

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/datasets#hasSourceURL">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/datasets#DataSource"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
        <rdfs:comment xml:lang="en">The endpoint URL of the datasource.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/datasets#hasFormat">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/datasets#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The data format of the dataset (e.g., GeoJSON, TIFF, CSV).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/datasets#lastIngested">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/datasets#Dataset"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The timestamp indicating when the dataset was last successfully ingested into the platform.</rdfs:comment>
    </owl:DatatypeProperty>
</rdf:RDF>
