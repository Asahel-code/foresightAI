<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.foresightai.org/ontology/core#"
     xml:base="http://www.foresightai.org/ontology/core"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:geography="http://www.foresightai.org/ontology/geography#"
     xmlns:hazards="http://www.foresightai.org/ontology/hazards#"
     xmlns:datasets="http://www.foresightai.org/ontology/datasets#">
    
    <owl:Ontology rdf:about="http://www.foresightai.org/ontology/core">
        <owl:imports rdf:resource="http://www.foresightai.org/ontology/geography"/>
        <owl:imports rdf:resource="http://www.foresightai.org/ontology/hazards"/>
        <owl:imports rdf:resource="http://www.foresightai.org/ontology/datasets"/>
    </owl:Ontology>

    <!-- Core Classes -->

    <owl:Class rdf:about="http://www.foresightai.org/ontology/core#Exposure">
        <rdfs:comment xml:lang="en">Represents the presence of people, livelihoods, species or ecosystems, environmental functions, services, and resources, infrastructure, or economic, social, or cultural assets in places and settings that could be adversely affected.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.foresightai.org/ontology/core#Vulnerability">
        <rdfs:comment xml:lang="en">Represents the propensity or predisposition to be adversely affected. Vulnerability encompasses a variety of concepts and elements including sensitivity or susceptibility to harm and lack of capacity to cope and adapt.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.foresightai.org/ontology/core#Impact">
        <rdfs:comment xml:lang="en">Represents the adverse effects or consequences of a hazard event.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.foresightai.org/ontology/core#EarlyAction">
        <rdfs:comment xml:lang="en">Represents actions taken to prevent or mitigate the impact of a foreseen hazard.</rdfs:comment>
    </owl:Class>

    <!-- Reference External / Imported Classes for Property Restrictions -->
    
    <owl:Class rdf:about="http://www.foresightai.org/ontology/geography#Location"/>
    <owl:Class rdf:about="http://www.foresightai.org/ontology/hazards#Hazard"/>
    <owl:Class rdf:about="http://www.foresightai.org/ontology/hazards#Observation"/>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/core#hasLocation">
        <rdfs:domain rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
        <rdfs:range rdf:resource="http://www.foresightai.org/ontology/geography#Location"/>
        <rdfs:comment xml:lang="en">Connects an entity to a geographical location.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/core#causes">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Hazard"/>
        <rdfs:range rdf:resource="http://www.foresightai.org/ontology/core#Impact"/>
        <rdfs:comment xml:lang="en">Indicates that a hazard leads to an impact.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/core#resultsIn">
        <rdfs:domain>
            <owl:Class>
                <owl:ClassUnion>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Exposure"/>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Vulnerability"/>
                </owl:ClassUnion>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.foresightai.org/ontology/core#Impact"/>
        <rdfs:comment xml:lang="en">Indicates that an exposure or vulnerability contributes to an impact.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/core#targets">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/core#EarlyAction"/>
        <rdfs:range>
            <owl:Class>
                <owl:ClassUnion>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Exposure"/>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Vulnerability"/>
                </owl:ClassUnion>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Indicates what an early action aims to address.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/core#affects">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Hazard"/>
        <rdfs:range>
            <owl:Class>
                <owl:ClassUnion>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Exposure"/>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Vulnerability"/>
                </owl:ClassUnion>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="en">Indicates what a hazard impacts.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/core#mitigates">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/core#EarlyAction"/>
        <rdfs:range rdf:resource="http://www.foresightai.org/ontology/core#Impact"/>
        <rdfs:comment xml:lang="en">Indicates which impact an early action aims to reduce or prevent.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Datatype Properties -->

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/core#hasDescription">
        <rdfs:domain>
            <owl:Class>
                <owl:ClassUnion>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#Impact"/>
                    <rdf:Description rdf:about="http://www.foresightai.org/ontology/core#EarlyAction"/>
                </owl:ClassUnion>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">A description of an impact or early action.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/core#hasEstimatedCost">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/core#Impact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">The estimated cost of an impact.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/core#hasAffectedPopulation">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/core#Impact"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The number of people affected by an impact.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/core#hasLeadTimeHours">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/core#EarlyAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">The lead time in hours required for an early action.</rdfs:comment>
    </owl:DatatypeProperty>

</rdf:RDF>
