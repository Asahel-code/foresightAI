<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.foresightai.org/ontology/hazards#"
     xml:base="http://www.foresightai.org/ontology/hazards"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.foresightai.org/ontology/hazards"/>

    <!-- Classes -->

    <owl:Class rdf:about="http://www.foresightai.org/ontology/hazards#Hazard">
        <rdfs:comment xml:lang="en">Represents a potential source of harm or danger (e.g., Flood, Drought).</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://www.foresightai.org/ontology/hazards#Observation">
        <rdfs:comment xml:lang="en">Represents an observation or measurement associated with environmental variables or hazards.</rdfs:comment>
    </owl:Class>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://www.foresightai.org/ontology/hazards#observes">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Observation"/>
        <rdfs:range rdf:resource="http://www.foresightai.org/ontology/hazards#Hazard"/>
        <rdfs:comment xml:lang="en">Connects an observation to the observed hazard or environmental state.</rdfs:comment>
    </owl:ObjectProperty>

    <!-- Datatype Properties -->

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/hazards#hasType">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Hazard"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The specific type of the hazard (e.g., Riverine Flood, Flash Flood).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/hazards#hasSeverity">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Hazard"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The severity level of the hazard (e.g., Low, Medium, High, Extreme).</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/hazards#hasTimestamp">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">The date and time when the observation was recorded.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/hazards#hasValue">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:comment xml:lang="en">The quantitative value of the observation.</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://www.foresightai.org/ontology/hazards#hasUnit">
        <rdfs:domain rdf:resource="http://www.foresightai.org/ontology/hazards#Observation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">The measurement unit of the observed value (e.g., mm, m^3/s).</rdfs:comment>
    </owl:DatatypeProperty>
</rdf:RDF>
